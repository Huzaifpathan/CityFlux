
    // ═══════════════════════════════════════════════════════════
    // 🔔 BOOKING NOTIFICATIONS COLLECTION
    // - Users can read their own notifications
    // - Users can create their own notifications (auto-generated)
    // - Users can update only isRead field of their notifications
    // - Users can delete their own notifications
    // ═══════════════════════════════════════════════════════════
    match /booking_notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      
      // Users can create their own notifications (userId must match)
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      
      // Users can update only isRead field of their own notifications
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      
      // Users can delete their own notifications
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      
      // Admin can read all notifications
      allow read: if isAdmin();
    }
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helper: get current user's role from the users collection
    // ─────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'citizen'; // Default to citizen if user document doesn't exist yet
    }

    function isCitizen() {
      return isAuthenticated() && getUserRole() == 'citizen';
    }

    function isPolice() {
      return isAuthenticated() && getUserRole() == 'police';
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    // ═══════════════════════════════════════════════════════════
    // 🔐 USERS COLLECTION
    // - Only authenticated users can access
    // - A user can read and write ONLY their own document
    // - No user can modify another user's profile
    // ═══════════════════════════════════════════════════════════
    match /users/{userId} {

      // user apna profile read/write kar sakta hai
      allow read, write: if isAuthenticated()
        && request.auth.uid == userId;

      // admin dashboard sab users read kar sakta hai
      allow read: if isAdmin();

      // ── Notifications sub-collection ──
      // Each user can only read/write their own notifications
      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid == userId;
      }

      // ── Saved Places sub-collection ──
      // Each user can only read/write their own saved places
      match /saved_places/{placeId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid == userId;
      }
    }

    // ═══════════════════════════════════════════════════════════
    // 📝 REPORTS COLLECTION
    // - Any authenticated user can create a new report
    //   (userId field must match their auth uid)
    // - All authenticated users can read reports
    // - Citizens can edit (update) ONLY their own reports
    // - Traffic Police can update ONLY the status field
    // - No one can delete reports
    // ═══════════════════════════════════════════════════════════
    match /reports/{reportId} {
      // All authenticated users can read reports
      allow read: if isAuthenticated();

      // Authenticated users can create reports; userId must match auth uid
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      // Citizens can update their own reports (any field)
      // Police can update status and assignedTo fields
      allow update: if isAuthenticated() && (
        // Citizen editing own report
        (isCitizen() && resource.data.userId == request.auth.uid)
        ||
        // Police updating status/assignedTo
        (isPolice()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'assignedTo']))
        ||
        // Admin can update any field
        isAdmin()
      );

      // No one can delete reports
      allow delete: if false;

      // ── Chat sub-collection ──
      // Police and the citizen who created the report can chat
      match /chat/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }

      // ── Proofs sub-collection ──
      // Police can upload action proofs, all authenticated can read
      match /proofs/{proofId} {
        allow read: if isAuthenticated();
        allow create: if isPolice()
          && request.resource.data.officerId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════
    // 🅿️ PARKING COLLECTION
    // - All authenticated users can read parking data
    // - Only Traffic Police or Admin can modify parking data
    // ═══════════════════════════════════════════════════════════
    match /parking/{parkingId} {
      allow read: if isAuthenticated();
      allow write: if isPolice() || isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // 🆘 SOS ALERTS COLLECTION
    // - Any authenticated user can create an SOS alert
    // - All authenticated users can read SOS alerts
    // - Only the creator or police/admin can update
    // ═══════════════════════════════════════════════════════════
    match /sos_alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid
        || isPolice()
        || isAdmin()
      );
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // 📢 ANNOUNCEMENTS COLLECTION
    // - All authenticated users can read
    // - Only police/admin can create/update
    // ═══════════════════════════════════════════════════════════
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isPolice() || isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // 🅿️ PARKING REPORTS COLLECTION
    // - Any authenticated user can create
    // - All authenticated users can read
    // ═══════════════════════════════════════════════════════════
    match /parking_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid
        || isPolice()
        || isAdmin()
      );
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // 🎫 BOOKINGS COLLECTION (Parking Reservations)
    // - Any authenticated user can create bookings (userId must match)
    // - Users can read only their own bookings
    // - Users can update only their own bookings (for cancellation, etc.)
    // - Police/Admin can read all bookings
    // - No one can delete bookings (maintain history)
    // ═══════════════════════════════════════════════════════════
    match /bookings/{bookingId} {
      // Users can read their own bookings, Police/Admin can read all
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid
        || isPolice()
        || isAdmin()
      );

      // Any authenticated user can create a booking (userId must match auth uid)
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      // Users can update their own bookings (cancel, extend, etc.)
      // Police/Admin can also update any booking
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid
        || isPolice()
        || isAdmin()
      );

      // No one can delete bookings (maintain booking history)
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // � PARKING VIOLATIONS COLLECTION
    // - Police can create violations (officerId must match auth uid)
    // - All authenticated users can read violations
    // - Police can update violations (status, notes, etc.)
    // - No one can delete violations
    // ═══════════════════════════════════════════════════════════
    match /parking_violations/{violationId} {
      // All authenticated users can read violations
      allow read: if isAuthenticated();

      // Police can create violations; officerId must match auth uid
      allow create: if isPolice()
        && request.resource.data.officerId == request.auth.uid;

      // Police can update violations
      // Admin can also update violations
      allow update: if isPolice() || isAdmin();

      // No one can delete violations (maintain audit trail)
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // �🚫 DENY EVERYTHING ELSE BY DEFAULT
    // Any collection not matched above is blocked
    // ═══════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
